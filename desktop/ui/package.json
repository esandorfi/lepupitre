{
  "name": "lepupitre-ui",
  "private": true,
  "version": "0.2.14",
  "description": "Local-first coach for preparing technical talks with daily quests, Boss Run audio sessions, actionable feedback, and peer review packs.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.vue",
    "lint:feature-rules": "node ../../scripts/check-ui-feature-rules.mjs",
    "lint:design": "node ./scripts/design-guard.mjs",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
